// smoothline.psh
// 
// Smooth Line shader
//=============================================================================

//=============================================================================
// Global variables
//=============================================================================

//=============================================================================
// Vertex shader output structure
//=============================================================================
struct VS_OUTPUT
{
	float4 Position  : POSITION;
	float4 Color0    : COLOR0;
	float2 Texcoord0 : TEXCOORD0;
	float4 Channel   : COLOR1;
};

//=============================================================================
// Pixel shader input structure
//=============================================================================
struct PS_OUTPUT
{
	float4 Color : COLOR;
};

float3 edge0;
float3 edge1;
float3 edge2;
float3 edge3;


//=============================================================================
// Pixel Shader
//=============================================================================
PS_OUTPUT PS( VS_OUTPUT In )
{
	PS_OUTPUT Out;
	
	float3 pos = float3(In.Texcoord0.x, In.Texcoord0.y, 1.0f);
	float4 d = float4(dot(edge0, pos), dot(edge1, pos), dot(edge2, pos), dot(edge3, pos));

	float alpha = 0.0f;

	
	if (all(d) >= 0)
	{
		float a = lerp(0.0f, 1.0f, min(d.y, d.w));
		alpha = lerp(0.0f, 1.3f, min(d.x, d.z) * clamp(a, 0.0f, 1.0f));
		alpha = clamp(alpha, 0.0f, 1.0f);
	}
	Out.Color = float4(1.0f, 1.0f, 1.0f, alpha);
	return Out;
}
