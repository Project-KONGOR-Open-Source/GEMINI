// 
// Reveal effect shader
//=============================================================================

//=============================================================================
// Global variables
//=============================================================================

//=============================================================================
// Vertex shader output structure
//=============================================================================
struct VS_OUTPUT
{
	float4 Color0 : COLOR0;
	float4 Texcoord0 : TEXCOORD0;
};

//=============================================================================
// Pixel shader input structure
//=============================================================================
struct PS_OUTPUT
{
	float4 Color : COLOR;
};

sampler gradient;
sampler reveal;

//=============================================================================
// Pixel Shader
//=============================================================================
PS_OUTPUT PS( VS_OUTPUT In )
{
	PS_OUTPUT Out;

    float4 cRevealColor = tex2D(reveal, In.Texcoord0);

    float fTime = In.Texcoord0.z;
    float fWidth = In.Texcoord0.w;

    float fReveal = saturate(((cRevealColor.a + fTime * (1.0f + fWidth)) - 1.0f) / fWidth);

	Out.Color = tex2D(gradient, float2(fReveal, 0.5f)) * In.Color0;
	
	return Out;
}
